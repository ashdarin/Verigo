VERIGO_APP_NAME=Verigo
VERIGO_MAX_EMAILS=5000
VERIGO_MAX_GUEST_EMAILS=100
VERIGO_FREE_SINGLE_DAILY_LIMIT=20
VERIGO_EMAIL_VERIFICATION_TRIAL_CREDITS=10
VERIGO_TRIAL_CREDIT_DAYS=7
VERIGO_MAX_WORKERS=8
VERIGO_MAX_PARALLEL_JOBS=1
VERIGO_MAX_PENDING_JOBS=5
# VERIGO_RESULTS_DIR=/opt/verigo/data/results
# VERIGO_DATABASE_PATH=/opt/verigo/data/verigo.db
VERIGO_MAX_IMPORT_BYTES=5242880
VERIGO_SESSION_TTL_DAYS=30
VERIGO_SECURE_COOKIES=false

# Optional: result notifications and catch-all probes.
# Generate new authorization codes. Never reuse or commit the leaked old values.
VERIGO_SENDER_EMAIL=
VERIGO_SENDER_PASSWORD=
VERIGO_PROBE_EMAIL=
VERIGO_PROBE_PASSWORD=

# Optional Tencent Cloud Studio on-demand lifecycle control.
VERIGO_CLOUDSTUDIO_LIFECYCLE_ENABLED=false
VERIGO_CLOUDSTUDIO_SECRET_ID=
VERIGO_CLOUDSTUDIO_SECRET_KEY=
VERIGO_CLOUDSTUDIO_REGION=
VERIGO_CLOUDSTUDIO_SPACE_KEY=
# SSH bootstrap after RunWorkspace. Register the matching public key in the
# Cloud Studio workspace SSH settings; keep the private key only on the VPS.
VERIGO_CLOUDSTUDIO_SSH_ENABLED=false
VERIGO_CLOUDSTUDIO_SSH_KEY_PATH=/opt/verigo/data/cloudstudio_worker_ed25519
VERIGO_CLOUDSTUDIO_SSH_KNOWN_HOSTS_PATH=/opt/verigo/data/cloudstudio_known_hosts
VERIGO_CLOUDSTUDIO_SSH_TOKEN_EXPIRY_SECONDS=300
