VERIGO_APP_NAME=Verigo
VERIGO_MAX_EMAILS=5000
VERIGO_MAX_GUEST_EMAILS=100
VERIGO_FREE_SINGLE_DAILY_LIMIT=20
VERIGO_EMAIL_VERIFICATION_TRIAL_CREDITS=10
VERIGO_TRIAL_CREDIT_DAYS=7
VERIGO_TRIAL_NETWORK_LIMIT=2
VERIGO_TRIAL_NETWORK_WINDOW_DAYS=7
# Comma-separated domains rejected at registration. Extend this list for your risk profile.
VERIGO_BLOCKED_EMAIL_DOMAINS=mailinator.com,yopmail.com,guerrillamail.com,tempmail.com,temp-mail.org,10minutemail.com,getnada.com,dispostable.com
VERIGO_TURNSTILE_SITE_KEY=
VERIGO_TURNSTILE_SECRET_KEY=
VERIGO_ADMIN_EMAILS=
# A random secret used only to hash daily visitor identifiers. Keep this stable.
VERIGO_METRICS_SALT=
VERIGO_MAX_WORKERS=8
VERIGO_MAX_PARALLEL_JOBS=1
VERIGO_MAX_PENDING_JOBS=5
VERIGO_QQ_SMTP_PER_MX=1
VERIGO_QQ_SMTP_WAIT_SECONDS=300
VERIGO_QQ_BACKOFF_BASE_SECONDS=30
VERIGO_QQ_BACKOFF_MAX_SECONDS=900
VERIGO_QQ_AVATAR_TIMEOUT_SECONDS=8
VERIGO_QQ_AVATAR_WAIT_SECONDS=20
VERIGO_QQ_AVATAR_MIN_INTERVAL_SECONDS=1
# Token for a Cloud Studio startup connectivity probe. Keep this secret.
VERIGO_CLOUDSTUDIO_PROBE_TOKEN=
# Enables a fixed Cloud Studio worker to authenticate and poll. Use a comma-separated
# account allowlist for a staged rollout, or * to route QQ jobs from every user and guest.
VERIGO_TENCENT_QQ_WORKER_ENABLED=false
VERIGO_TENCENT_QQ_WORKER_ALLOWED_EMAILS=
VERIGO_TENCENT_QQ_WORKER_TOKEN=
# Optional on-demand lifecycle control through Tencent Cloud API 3.0.
VERIGO_CLOUDSTUDIO_LIFECYCLE_ENABLED=false
VERIGO_CLOUDSTUDIO_SECRET_ID=
VERIGO_CLOUDSTUDIO_SECRET_KEY=
VERIGO_CLOUDSTUDIO_REGION=
VERIGO_CLOUDSTUDIO_SPACE_KEY=
VERIGO_CLOUDSTUDIO_WORKER_ONLINE_SECONDS=45
VERIGO_CLOUDSTUDIO_STARTUP_TIMEOUT_SECONDS=300
VERIGO_CLOUDSTUDIO_WAKE_MAX_ATTEMPTS=3
VERIGO_CLOUDSTUDIO_WAKE_RETRY_SECONDS=15
VERIGO_CLOUDSTUDIO_IDLE_STOP_SECONDS=600
VERIGO_CLOUDSTUDIO_LIFECYCLE_POLL_SECONDS=5
VERIGO_RESULTS_DIR=/opt/verigo/data/results
VERIGO_DATABASE_PATH=/opt/verigo/data/verigo.db
VERIGO_MAX_IMPORT_BYTES=5242880
VERIGO_SESSION_TTL_DAYS=30
VERIGO_SECURE_COOKIES=true

VERIGO_SENDER_EMAIL=
VERIGO_SENDER_PASSWORD=
VERIGO_PROBE_EMAIL=
VERIGO_PROBE_PASSWORD=
